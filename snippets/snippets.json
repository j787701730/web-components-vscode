{
  "创建 Web Components 模板": {
    "prefix": "js-webComponents",
    "body": [
      "if (!customElements.get('${TM_FILENAME_BASE}')) {",
      "  const template = document.createElement('template');",
      "  template.innerHTML = /*html*/ `",
      "    <style>",
      "     :host {",
      "       display: contents;",
      "     }",
      "     ::slotted(*) { }",
      "    </style>",
      "    <div>",
      "      <slot></slot>",
      "    </div>",
      "  `;",
      "",
      "  customElements.define(",
      "    '${TM_FILENAME_BASE}',",
      "    class extends HTMLElement {",
      "      constructor() {",
      "        super();",
      "      }",
      "",
      "      /** 组件挂载到 DOM */",
      "      connectedCallback() {",
      "        const shadowRoot = this.attachShadow({ mode: 'open' });",
      "        shadowRoot.appendChild(template.content.cloneNode(true));",
      "      }",
      "",
      "      /** 声明需要监听的属性 */",
      "      static get observedAttributes() {",
      "        return [];",
      "      }",
      "",
      "      /** 监听属性变化 */",
      "      attributeChangedCallback(name, oldVal, newVal) {}",
      "",
      "      /** 组件从 DOM 移除 */",
      "      disconnectedCallback() {",
      "        this.shadowRoot.innerHTML = '';",
      "      }",
      "    },",
      "  );",
      "}",
      ""
    ],
    "description": "创建 Web Component 模板"
  },
  "创建 Web Components Lite 模板": {
    "prefix": "js-webComponents-lite",
    "body": [
      "if (!customElements.get('${TM_FILENAME_BASE}')) {",
      "  customElements.define(",
      "    '${TM_FILENAME_BASE}',",
      "    class extends HTMLElement {",
      "      constructor() {",
      "        super();",
      "      }",
      "",
      "      /** 组件挂载到 DOM */",
      "      connectedCallback() {",
      "        const shadowRoot = this.attachShadow({ mode: 'open' });",
      "        shadowRoot.innerHTML = '';",
      "      }",
      "",
      "      /** 声明需要监听的属性 */",
      "      static get observedAttributes() {",
      "        return [];",
      "      }",
      "",
      "      /** 监听属性变化 */",
      "      attributeChangedCallback(name, oldVal, newVal) {}",
      "",
      "      /** 组件从 DOM 移除 */",
      "      disconnectedCallback() {",
      "        this.shadowRoot.innerHTML = '';",
      "      }",
      "    },",
      "  );",
      "}",
      ""
    ],
    "description": "创建 Web Component Lite 模板"
  },
  "创建 DispatchEvent": {
    "prefix": "js-dispatchEvent",
    "body": [
      "/* ! 添加 $1 自定义事件 */",
      "const event = new CustomEvent('$1', {",
      "  detail: {",
      "    value: ${2:''}",
      "  }",
      "});",
      "this.dispatchEvent(event);",
      ""
    ],
    "description": "创建 DispatchEvent"
  },
  "创建 AbortController": {
    "prefix": "js-abortController",
    "body": ["this.controller = new AbortController();"],
    "description": "创建 AbortController"
  },
  "创建 abort AbortController": {
    "prefix": "js-abortController-abort",
    "body": ["this.controller?.abort();"],
    "description": "创建 abort AbortController"
  },
  "创建 addEventListener signal": {
    "prefix": "js-addEventListener",
    "body": [
      "$1.addEventListener(",
      "  '$2',",
      "  (e) => {",
      "    $3",
      "  }, ",
      "  { signal: this.controller.signal }, ",
      ");"
    ],
    "description": "创建 addEventListener signal"
  },
  "创建 slot 节点发生变化事件": {
    "prefix": "js-slotchange",
    "body": ["$1.addEventListener(", "  'slotchange',", "  (e) => {", "    $2", "  }, ", ");"],
    "description": "创建 slot 节点发生变化事件"
  },
  "获取 slot 节点(包含元素、文本)": {
    "prefix": "js-assignedNodes",
    "body": ["$1.assignedNodes({ flatten: true });"],
    "description": "获取 slot 节点(包含元素、文本)"
  },
  "获取 slot 所有元素(过滤文本节点)": {
    "prefix": "js-assignedElements",
    "body": ["$1.assignedElements({ flatten: true });"],
    "description": "获取 slot 所有元素(过滤文本节点)"
  },
  "判断 slot 是否为空": {
    "prefix": "js-assignedNodes-empty",
    "body": ["$1.assignedNodes({ flatten: true }).length === 0"],
    "description": "判断 slot 是否为空"
  }
}
